{:assert {:ssh-key {:src "test -f ~/.ssh/juxt_mac_osm && test -f ~/.ssh/juxt_mac_osm.pub"
                    :message "SSH identity key not found"
                    :instructions ["Generate: ssh-keygen -t ed25519 -f ~/.ssh/juxt_mac_osm"
                                   "Add to ssh-agent: ssh-add ~/.ssh/juxt_mac_osm"
                                   "Add public key to GitHub: gh ssh-key add ~/.ssh/juxt_mac_osm.pub --type signing"]}}
 :pkg/brew {:mosh {}}
 :fs/symlink-folder {"~/.ssh" "./.ssh"}}
