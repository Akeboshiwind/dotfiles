-- allium: 1
-- Dotfiles Manager Specification
-- A declarative system for managing dotfiles, packages, and system configuration
--
-- Two phases: check (read-only, builds plan) and execute (mutates).
-- Two commands: plan (check + print) and apply (check + execute).

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ActionRef {
    type: ActionType
    key: String
}

value DependencyError {
    kind: cycle | missing_provider | duplicate_provider
    details: String
}

value SecretValue {
    content: String?
    disabled: Boolean    -- true when secret is explicitly disabled
}

value SymlinkMapping {
    target: String    -- destination path (may contain ~)
    source: String    -- source file path (canonical)
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum ActionType {
    -- Package managers
    pkg_brew
    pkg_mise
    pkg_mas
    pkg_bbin
    pkg_npm
    pkg_script

    -- Package orphan uninstall (dynamically generated)
    pkg_brew_uninstall
    pkg_mise_uninstall
    pkg_mas_uninstall
    pkg_bbin_uninstall

    -- Filesystem
    fs_symlink
    fs_symlink_folder
    fs_unlink

    -- System configuration
    osx_defaults
    brew_service

    -- Assertions
    assert

    -- Git
    git_clone

    -- Claude
    claude_marketplace
    claude_plugin
    claude_mcp
}

enum DriftKind { missing | outdated | wrong | orphan }

enum CheckOutcome {
    satisfied                      -- in desired state, no action needed
    drift_missing                  -- diverged: not present
    drift_outdated                 -- diverged: version behind
    drift_wrong                    -- diverged: wrong value/target
    drift_orphan                   -- diverged: should not exist
    unknown                        -- cannot determine (e.g. script with no :check)
    conflict                       -- blocked by incompatible existing state
    error                          -- cannot proceed (tool missing, validation failed)
    cancelled                      -- upstream action failed/conflicted
}

------------------------------------------------------------
-- Run Mode
------------------------------------------------------------

-- The entry point to the system. Determines what happens after
-- the check phase completes.

enum RunMode {
    plan       -- check phase only, print results
    apply      -- check phase + execute phase
}

entity RunConfig {
    mode: RunMode
    action_filter: ActionType?
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Manifest {
    plan: List<PlanEntry>
}

entity PlanEntry {
    -- One of: keyword reference, file path, or inline map
    kind: keyword | path | inline
    value: String       -- keyword name, path, or inline content
    source_dir: String? -- directory for relative path resolution
}

entity ResolvedEntry {
    step: ActionMap
    source: String?     -- base directory for path resolution
}

entity ActionMap {
    -- Map of ActionType -> {key -> options}
    -- Dynamic structure based on action types
    actions: Map<ActionType, Map<String, ActionOptions>>
}

entity ActionOptions {
    -- Base options available to all actions
    dep_provides: Set<Capability>?
    dep_requires: Set<ActionRef | Capability>?

    -- Action-specific options handled by each action type
}

entity ActionGraph {
    -- The plan artifact. A dependency graph where each node
    -- accumulates state through the check and execute phases.
    nodes: Map<ActionRef, ActionNode>
    edges: Map<ActionRef, Set<ActionRef>>   -- dependency edges
    order: List<ActionRef>                  -- topological order
    symlinks: Map<String, String>           -- target -> source
}

entity ActionNode {
    ref: ActionRef
    opts: ActionOptions
    check: CheckOutcome?    -- populated during check phase
    result: ExecutionResult? -- populated during execute phase
}

value ExecutionResult {
    status: ok | error
    message: String?
}

entity Cache {
    symlinks: Map<String, String>    -- target -> source from last run
    scripts: Map<String, ScriptRecord> -- script name -> last run info
}

value ScriptRecord {
    timestamp: Instant
    content_hash: String?
}

entity Secrets {
    values: Map<String, SecretValue>
}

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- Action capabilities that can be provided/required
external entity Capability {
    name: String
}

-- Filesystem
external entity File {
    path: String
    exists: Boolean
    is_symlink: Boolean
    symlink_target: String?
}

external entity Directory {
    path: String
    files: List<File>
}

------------------------------------------------------------
-- Defaults
------------------------------------------------------------

config {
    cache_dir: String = "${XDG_CACHE_HOME:-~/.cache}/dotfiles"
    manifest_file: String = "manifest.edn"
    secrets_file: String = "secrets.edn"
}

-- Derived from config
-- cache_file: config.cache_dir + "/cache.edn"

------------------------------------------------------------
-- Action Protocol
------------------------------------------------------------

-- Every action type implements two methods:
--
--   check(key, opts) -> CheckOutcome
--     Read-only. Queries live system state and returns the
--     current state of this action. Called during check phase.
--
--   install(key, opts)
--     Mutates. Brings the system into the desired state.
--     Only called during execute phase, and only for actions
--     whose check returned drift or unknown.

------------------------------------------------------------
-- Rules: Manifest Loading
------------------------------------------------------------

rule LoadManifest {
    when: run: RunConfig

    let manifest = read_edn(config.manifest_file)
    let entries = manifest.plan.map(e => resolve_entry(e))

    requires: config.manifest_file != null

    ensures: Manifest.created(plan: entries)
}

rule ResolveKeywordEntry {
    when: entry: PlanEntry with kind = keyword

    let path = "cfg/" + entry.value + "/manifest.edn"
    let content = read_edn(path)

    requires: file_exists(path)

    ensures: ResolvedEntry.created(
        step: content,
        source: parent_dir(path)
    )
}

rule ResolvePathEntry {
    when: entry: PlanEntry with kind = path

    let content = read_edn(entry.value)

    requires: file_exists(entry.value)

    ensures: ResolvedEntry.created(
        step: content,
        source: parent_dir(entry.value)
    )
}

rule ResolveInlineEntry {
    when: entry: PlanEntry with kind = inline

    ensures: ResolvedEntry.created(
        step: entry.value,
        source: null
    )
}

------------------------------------------------------------
-- Rules: Secrets
------------------------------------------------------------

rule LoadSecrets {
    when: run: RunConfig

    ensures:
        if file_exists(config.secrets_file):
            Secrets.created(values: read_edn(config.secrets_file))
        else:
            Secrets.created(values: {})
}

rule ValidateSecrets {
    when: secrets: Secrets.created

    -- Empty secret values are caught during the check phase.
    -- Each action that references a secret will receive an error
    -- CheckOutcome if the secret is empty (not disabled).

    let empty_values = secrets.values
        .filter(entry => not entry.disabled and (entry.content = null or entry.content = ""))

    ensures:
        for entry in empty_values:
            SecretError.created(key: entry.key)
}

rule ResolveSecretReference {
    when: SecretTagEncountered(key)

    -- Looks up key in secrets map. Throws if key not found.
    -- Note: does NOT check for disabled secrets - a disabled value
    -- is returned as-is. Validation catches empty values separately.

    let secrets = Secrets

    requires: key in secrets.values

    ensures: SecretResolved(value: get(secrets.values, key))
}

------------------------------------------------------------
-- Rules: Plan Building
------------------------------------------------------------

rule ResolveSymlinkPaths {
    when: entry: ResolvedEntry.created

    -- Resolve relative paths in fs_symlink and fs_symlink_folder
    -- against the entry's source directory

    let symlinks = get(entry.step, fs_symlink)

    ensures:
        for mapping in symlinks:
            if is_relative(mapping.source) and starts_with(canonical(entry.source, mapping.source), entry.source):
                mapping.source = canonical(entry.source, mapping.source)
}

rule ExpandSymlinkFolder {
    when: entry: ResolvedEntry.created

    let folder_mappings = get(entry.step, fs_symlink_folder)

    requires: folder_mappings != null

    -- Expand each {prefix -> dir} into individual symlinks

    ensures:
        for mapping in folder_mappings:
            let files = list_files(mapping.dir)
            for file in files:
                set(entry.step, fs_symlink, mapping.prefix + relative_path(mapping.dir, file), file.path)
        set(entry.step, fs_symlink_folder, null)
}

rule DetectDuplicateKeys {
    when: EntriesReadyForMerge(entries)

    let duplicates = find_keys_in_multiple_entries(entries)

    -- Duplicate keys are a graph-building error, not a check-phase error.
    -- Thrown immediately like other DependencyErrors.

    requires: duplicates.count = 0
}

rule MergeEntries {
    when: EntriesValidated(entries)

    ensures: ActionMap.created(
        actions: merge_all(entries.map(e => e.step))
    )
}

rule CalculateStaleSymlinks {
    when: plan: ActionMap.created

    let cache = Cache
    let current_symlinks = get(plan.actions, fs_symlink)
    let cached_symlinks = cache.symlinks
    let stale = cached_symlinks.keys - current_symlinks.keys

    ensures:
        if stale.count > 0:
            set(plan.actions, fs_unlink, cached_symlinks.filter(k => k in stale))
}

rule CalculateOrphans {
    when: plan: ActionMap.created

    -- For each action type that supports orphan detection,
    -- query live system state and compare against declared items.
    -- Each action type's orphans implementation returns a plan
    -- fragment (e.g. {pkg_brew_uninstall: {...}}) or null.
    -- Currently supported: pkg_brew, pkg_mise, pkg_mas, pkg_bbin.

    let orphan_fragments = compact(plan.action_types.map(type => detect_orphans(type, get(plan.actions, type))))

    ensures:
        for fragment in orphan_fragments:
            plan.actions = plan.actions.merge(fragment)
}

------------------------------------------------------------
-- Rules: Dependency Graph
------------------------------------------------------------

-- Graph validation fails fast: if any error is found, an exception
-- is thrown immediately and execution stops. Graph errors are not
-- recoverable.

rule BuildActionGraph {
    when: PlanReadyForValidation(plan)

    let actions = all_action_refs(plan)
    let providers = find_providers(plan)      -- capability -> action ref
    let requirements = find_requirements(plan) -- action ref -> set of requirements

    ensures: ActionGraph.created(
        nodes: actions.map(a => ActionNode{ref: a, opts: get(plan, a)}),
        edges: resolve_edges(providers, requirements),
        order: topo_sort(edges)
    )
}

rule ValidateActionGraph {
    when: graph: ActionGraph.created

    -- All three checks happen in a single pass.
    -- Any error throws immediately (fail-fast).

    let duplicates = capabilities_with_multiple_providers(graph)
    let missing = requirements_without_providers(graph)

    requires: duplicates.count = 0
    requires: missing.count = 0

    -- Cycle detection only runs when no duplicate/missing errors
    let cycles = detect_cycles(graph)

    requires: cycles.count = 0
}

------------------------------------------------------------
-- Rules: Synthetic Batch-Complete Capabilities
------------------------------------------------------------

-- For each action type present in the graph, a synthetic capability
-- complete(<action-type>) is automatically generated. This capability
-- is provided when all actions of that type complete successfully
-- during the execute phase.
--
-- This is a generic mechanism. Its primary use is orphan uninstall
-- actions requiring their corresponding install type to complete first.

rule GenerateBatchCompleteCapabilities {
    when: GraphValidated(graph)

    let present_types = graph.nodes.map(n => n.ref.type).distinct

    ensures:
        for type in present_types:
            -- Synthetic capability depends on all actions of this type
            Capability.created(
                name: complete_capability(type)
            )
}

rule OrphanRequiresBatchComplete {
    when: node: ActionNode.created
    requires: node.ref.type in {pkg_brew_uninstall, pkg_mise_uninstall,
                                 pkg_mas_uninstall, pkg_bbin_uninstall}

    ensures: node.opts.dep_requires = {complete_capability(corresponding_install_type(node.ref.type))}
    -- e.g. pkg_brew_uninstall requires complete(pkg_brew)
}

------------------------------------------------------------
-- Rules: Action Requirements
------------------------------------------------------------

-- Actions declare what capability they require to run.
-- nil = standalone (no dependencies)
-- keyword = requires that capability to be provided

rule ActionRequiresCapability {
    -- Package managers require their capability to be provided
    when: node: ActionNode.created
    requires: node.ref.type in {pkg_brew, pkg_mise, pkg_mas, pkg_bbin, pkg_npm,
                                 brew_service, claude_marketplace, claude_plugin, claude_mcp}
    ensures: node.opts.dep_requires = {capability_for(node.ref.type)}
}

rule GitCloneRequiresGit {
    when: node: ActionNode.created
    requires: node.ref.type = git_clone
    ensures: node.opts.dep_requires = {git_capability}
}

rule StandaloneActions {
    -- These actions have no external dependencies
    when: node: ActionNode.created
    requires: node.ref.type in {fs_symlink, fs_unlink, osx_defaults, pkg_script, assert}
    ensures: node.opts.dep_requires = {}
}

------------------------------------------------------------
-- Rules: Check Phase
------------------------------------------------------------

-- Walk the graph in topological order. For each node, run check.
-- Store the CheckOutcome on the node. On conflict or error,
-- mark all downstream nodes as cancelled (don't check them).

rule CheckPhase {
    when: GraphValidated(graph)

    ensures:
        for node in graph.order:
            if node.check != cancelled:
                let outcome = check(node.ref.type, node.ref.key, node.opts)
                node.check = outcome

                if outcome in {conflict, error}:
                    for downstream in graph.dependents(node.ref):
                        downstream.check = cancelled
}

-- Validation rules are now part of the check phase.
-- Actions with invalid configuration return error CheckOutcome
-- from their check implementation.

rule ValidateMiseVersion {
    -- Implemented within pkg/mise check:
    -- if opts.version = null, check returns error("Version required")
}

rule ValidateScriptSource {
    -- Implemented within pkg/script check:
    -- if opts.path = null and opts.src = null,
    -- check returns error("Either :path or :src required")
    --
    -- Scripts may optionally declare :check (path or src).
    -- If :check is present, run it during check phase:
    --   exit 0 = satisfied, exit 1 = drift_missing
    -- If :check is absent, return unknown.
    -- Cache provides last-run info via env vars to the check script.
}

rule ValidateAssertSource {
    -- Implemented within assert check:
    -- if opts.path = null and opts.src = null,
    -- check returns error("Either :path or :src required")
}

------------------------------------------------------------
-- Rules: Plan Command
------------------------------------------------------------

rule ShowPlan {
    when: GraphChecked(graph, run)
    requires: run.mode = plan

    -- Print the check results from the graph.
    -- Group by outcome for readability.

    ensures:
        for node in graph.order:
            if node.check != satisfied:
                CheckResultDisplayed(node.ref, node.check)
        PlanSummaryDisplayed(frequency_of(graph.nodes.map(n => n.check)))
}

------------------------------------------------------------
-- Rules: Execute Phase
------------------------------------------------------------

rule ExecutePhase {
    when: GraphChecked(graph, run)
    requires: run.mode = apply

    -- Walk the graph in topological order.
    -- Only run install for nodes with drift or unknown outcome.
    -- Satisfied nodes are skipped. Conflict/error/cancelled are
    -- already handled by the check phase.
    --
    -- On install failure, mark downstream nodes as cancelled.

    let batches = partition_by_type(graph.order)

    ensures:
        for batch in batches:
            let actionable = batch.filter(n => n.check in {drift_missing, drift_outdated, drift_wrong, drift_orphan, unknown})
            let already_cancelled = batch.filter(n => n.check in {conflict, error, cancelled})

            if actionable.count > 0:
                let results = install_batch(batch.type, actionable)
                for pair in zip(actionable, results):
                    pair.node.result = pair.result
                    if pair.result.status = error:
                        for downstream in graph.dependents(pair.node.ref):
                            if downstream.check not in {conflict, error, cancelled}:
                                downstream.check = cancelled

        let failed = graph.nodes.filter(n => n.result?.status = error)
        let cancelled = graph.nodes.filter(n => n.check = cancelled)
        if failed.count > 0 or cancelled.count > 0:
            SummaryDisplayed(failed.count, cancelled.count)
}

------------------------------------------------------------
-- Rules: Action Execution (deferred to action-specific specs)
------------------------------------------------------------

-- Each action type implements both check and install.
-- See the corresponding action spec for details.

deferred BrewAction           -- see: actions/brew
deferred BrewUninstallAction  -- see: actions/brew (orphan cleanup)
deferred BrewServiceAction    -- see: actions/brew
deferred MiseAction           -- see: actions/mise
deferred MiseUninstallAction  -- see: actions/mise (orphan cleanup)
deferred MasUninstallAction   -- see: actions/mas (orphan cleanup)
deferred BbinAction           -- see: actions/bbin
deferred BbinUninstallAction  -- see: actions/bbin (orphan cleanup)
deferred NpmAction            -- see: actions/npm
deferred ScriptAction         -- see: actions/script
deferred AssertAction         -- see: actions/assert
deferred SymlinkAction        -- see: actions/symlink
deferred UnlinkAction         -- see: actions/symlink
deferred OsxDefaultsAction    -- see: actions/osx
deferred GitCloneAction       -- see: actions/git
deferred ClaudeMarketplaceAction -- see: actions/claude
deferred ClaudePluginAction   -- see: actions/claude
deferred ClaudeMcpAction      -- see: actions/claude

------------------------------------------------------------
-- Rules: Symlink Actions (inline - these are core behaviour)
------------------------------------------------------------

rule SymlinkCheck {
    when: CheckAction(fs_symlink, target, opts)

    let target_file = expand_tilde(target)
    let source = opts.source

    ensures:
        if file_exists(target_file) and is_symlink(target_file) and points_to(target_file, source):
            outcome = satisfied

        else if file_exists(target_file) and is_symlink(target_file):
            -- Points to wrong target, can be re-linked
            outcome = drift_wrong

        else if file_exists(target_file):
            -- Regular file/dir exists, refuse to overwrite
            outcome = conflict

        else:
            outcome = drift_missing
}

rule SymlinkInstall {
    when: InstallAction(fs_symlink, target, opts)

    let target_file = expand_tilde(target)
    let source = opts.source

    ensures:
        create_parent_dirs(target_file)
        create_symlink(source, target_file)
}

rule UnlinkCheck {
    when: CheckAction(fs_unlink, target, opts)

    let target_file = expand_tilde(target)
    let expected_source = opts.source

    ensures:
        if not file_exists(target_file):
            outcome = satisfied    -- already gone

        else if not is_symlink(target_file):
            outcome = conflict     -- not a symlink, refuse to touch

        else if not points_to(target_file, expected_source):
            outcome = conflict     -- points elsewhere, refuse to touch

        else:
            outcome = drift_orphan
}

rule UnlinkInstall {
    when: InstallAction(fs_unlink, target, opts)

    let target_file = expand_tilde(target)

    ensures:
        delete(target_file)
}

------------------------------------------------------------
-- Rules: Cache Update
------------------------------------------------------------

rule UpdateCache {
    when: GraphExecuted(graph, run)
    requires: run.mode = apply

    -- Always update cache regardless of action_filter.
    -- Symlinks are computed from the full manifest (not filtered).
    -- Script records are loaded from the existing cache and only
    -- updated additively by scripts that actually ran.

    let new_cache = Cache{
        symlinks: graph.symlinks,
        scripts: updated_script_records(graph)
    }

    ensures:
        create_dirs(config.cache_dir)
        atomically_write(config.cache_dir + "/cache.edn", new_cache)
}

------------------------------------------------------------
-- Open Questions
------------------------------------------------------------

open question "Should symlink conflicts be auto-resolved with backup?"
open question "Should there be rollback on partial failure?"
open question "Should disabled secrets be rejected when a secret tag references them? Currently the value is returned as-is."
open question "Interactive plan -> approve -> apply flow?"
open question "How should action_filter interact with synthetic complete() capabilities?"
