-- allium: 3
-- syn.allium — behavioural specification of "syn", the dotfile manager

-- Scope: the dotfile-manager engine (manifest → plan → check → report/apply)
-- Includes: manifest and module loading, plan assembly (path resolution,
--   symlink-folder expansion, duplicate detection), stale-symlink cleanup,
--   orphan detection (packages and third-party package sources),
--   package-source trust, capability-based dependency ordering, the check phase,
--   plan display, apply execution with failure propagation, symlink-ownership
--   and script-run caching, secrets validation, persisted-plan capture (a plan
--   run records its checked plan) and replay (a default apply replays a valid
--   persisted plan, skipping the live check phase).
-- Excludes:
--   - The contents of individual cfg/* modules (declarative data, not behaviour)
--   - Terminal rendering, colours and output layout (display.clj)
--   - Cache file location, EDN format and atomic-write mechanics (cache.clj)
--   - Action-namespace auto-discovery (registry.clj)
--   - The exact shell commands each package manager runs

given {
    cache: StateCache
    manifest: Manifest
}

-- =============================================================================
-- External world
-- =============================================================================

external entity Operator {
    -- The human running syn at a terminal on their own machine.
    name: String
}

external entity PackageManager {
    -- A package manager syn can drive: brew, mise, mas, bbin, npm, uv.
    name: String
    available: Boolean                    -- the manager's command exists on PATH
    supports_orphan_detection: Boolean
    explicitly_installed: Set<String>     -- user-requested items only, not transitive dependencies
    third_party_sources: Set<String>      -- installed sources outside the manager's
                                          -- official registry (e.g. brew taps)
}

external entity SourceFile {
    -- A file inside the repository, discovered when expanding a symlink folder.
    relative_path: String                 -- path relative to the declared folder
    absolute_path: String
}

-- =============================================================================
-- Manifest
-- =============================================================================

entity Manifest {
    modules: Module with manifest = this
    folder_declarations: FolderDeclaration with manifest = this

    identity: String                      -- hash identifying this manifest; a
                                          -- persisted plan is valid to replay only
                                          -- against a manifest with the same identity
    references_undefined_secret: Boolean  -- some module refers to a secret key
                                          -- that is not defined
    has_escaping_source: modules.any(m => m.has_escaping_source)
}

entity FolderDeclaration {
    -- A symlink-folder declaration: link every file under a repository folder.
    manifest: Manifest
    link_prefix: String                   -- where the links land, e.g. "~/.config/fish"
    files: Set<SourceFile>                -- files discovered under the declared folder
}

entity Module {
    -- One entry in the root manifest plan: a cfg/<name>/manifest.edn file
    -- or an inline declaration block.
    manifest: Manifest
    source_dir: String?                   -- null for inline entries
    has_escaping_source: Boolean          -- a declared relative source path resolves
                                          -- outside source_dir
}

entity Secret {
    key: String
    value: String?
    disabled: Boolean                     -- explicitly marked as not in use

    invalid: not disabled and (value = null or value = "")
}

-- =============================================================================
-- State cache
-- =============================================================================

entity StateCache {
    -- Persisted between runs. Records which symlinks syn owns (so links removed
    -- from the manifest can be cleaned up), which scripts have run, and the most
    -- recently captured plan (so a later apply can replay it).
    recorded_symlinks: RecordedSymlink with cache = this
    script_records: ScriptRecord with cache = this
    stored_plan: StoredPlan with cache = this   -- at most one; the last plan captured
}

entity RecordedSymlink {
    cache: StateCache
    target: String
    source: String
}

entity ScriptRecord {
    cache: StateCache
    script_name: String
    content_hash: String                  -- identity of the script content that last ran successfully
}

entity StoredPlan {
    -- A plan captured by a plan-mode run at the end of its check phase, so a
    -- later default apply can replay the recorded decisions without repeating
    -- the expensive live queries. The checked actions and validation errors it
    -- replays live on source_run, whose plan this captured.
    cache: StateCache
    source_run: Run                       -- the plan run whose checked plan this is
    manifest_identity: String             -- identity of the manifest it was built from
    scope: String?                        -- the scope in force when it was captured
    spent: Boolean                        -- consumed by a prior successful replay-apply
    captured_at: Timestamp                -- when the plan was persisted

    -- A stored plan is valid to replay for an invocation only when it was built
    -- from the same manifest, under the same scope, has not been consumed, and
    -- was captured within the TTL window (so drift that happened while the
    -- operator was away between plan and apply forces a fresh check).
    valid_for(current_identity, current_scope):
        not spent
        and manifest_identity = current_identity
        and ((scope = null and current_scope = null) or scope = current_scope)
        and now - captured_at <= config.plan_ttl
}

-- =============================================================================
-- Run and actions
-- =============================================================================

entity Run {
    mode: plan | apply
    scope: String?                        -- optional action-type filter, e.g. ":pkg/brew"
    fresh: Boolean                        -- the --fresh flag: ignore any persisted plan and
                                          -- check live (only meaningful when mode = apply;
                                          -- plan mode always checks live)
    status: planning | checking | displaying | applying | complete | aborted

    replayed_plan: StoredPlan?            -- the persisted plan this apply run replayed;
                                          -- null on the live-check path

    graph_errors: Boolean                 -- the capability graph has a cycle, a required
                                          -- capability with no provider, or a capability
                                          -- with more than one provider

    actions: Action with run = this
    validation_errors: ValidationError with run = this

    unsatisfied_actions: actions where check_outcome != satisfied
    warned_actions: actions where check_outcome = satisfied and check_message != null
    all_checked: actions.all(a => a.check_outcome != unchecked)
    all_resolved: actions.all(a => a.result != pending)

    transitions status {
        planning -> checking
        planning -> applying              -- replay: skip the live check phase
        planning -> aborted
        checking -> displaying
        checking -> applying
        checking -> aborted
        displaying -> complete
        applying -> complete
        terminal: complete, aborted
    }
}

entity ValidationError {
    run: Run
    subject: String                       -- the offending declaration or secret key
    description: String
}

entity Action {
    run: Run
    key: String
    kind: SymlinkAction | UnlinkAction | PackageAction | UninstallAction |
          SourceRemovalAction | ScriptAction | AssertAction | ServiceAction |
          DefaultsAction | GitCloneAction | ClaudeResourceAction

    declaring_modules: Set<Module>        -- modules that declared this (type, key)
    provides: Set<String>                 -- capability keywords this action enables
    depends_on: Set<Action>               -- resolved capability and explicit dependencies

    in_scope: Boolean                     -- true when run.scope = null; otherwise true only if
                                          -- the action's type matches the scope (or its
                                          -- uninstall variant), or the action is a transitive
                                          -- dependency of one that does

    check_outcome: unchecked | satisfied | drift | unknown | conflict | error | cancelled
    drift_kind: missing | outdated | wrong | orphan when check_outcome = drift
    check_message: String?

    result: pending | applied | skipped | failed

    install_succeeds: Boolean             -- live outcome of attempting the action

    actionable: check_outcome in {drift, unknown}
    blocking: check_outcome in {error, conflict, cancelled}
}

variant SymlinkAction : Action {
    target: String                        -- where the link lives (may be under ~)
    source: String                        -- file inside the repository

    -- Live filesystem state at check time:
    target_exists: Boolean
    target_is_symlink: Boolean
    target_points_at_source: Boolean
}

variant UnlinkAction : Action {
    target: String
    expected_source: String               -- what the cache says the link should point at

    target_exists: Boolean
    target_is_symlink: Boolean
    target_points_at_expected: Boolean
}

variant PackageAction : Action {
    manager: PackageManager
    version: String?                      -- pinned version, or "latest"
    source: String?                       -- third-party source the item comes from
                                          -- (e.g. a brew tap); null for official items
    trust_declared: Boolean               -- the manifest declares :trust for this item

    installed: Boolean
    upgrade_available: Boolean            -- a newer version exists than the one installed
    installed_version: String?
    desired_version: String?
    trusted: Boolean?                     -- live: whether the operator has granted the
                                          -- manager's required trust for this item; null
                                          -- when trust does not apply (official source,
                                          -- or the manager imposes no trust requirement)
}

variant UninstallAction : Action {
    manager: PackageManager
}

variant SourceRemovalAction : Action {
    -- Removal of an orphaned third-party package source (e.g. a brew tap).
    manager: PackageManager
    source: String
}

variant ScriptAction : Action {
    content: String
    has_check: Boolean                    -- a check command was declared
    check_passes: Boolean                 -- live: the check command exits successfully
    content_changed: Boolean              -- no successful run of this exact content is
                                          -- recorded in the cache
}

variant AssertAction : Action {
    condition_holds: Boolean              -- live evaluation of the assertion
    message: String?
    instructions: List<String>?           -- manual remediation steps shown to the operator
}

variant ServiceAction : Action {
    running: Boolean
    root_owned: Boolean                   -- the service runs as root
    needs_sudo: Boolean                   -- declared as a sudo-managed service
}

variant DefaultsAction : Action {
    -- A macOS defaults domain with one or more desired key/value settings.
    all_values_match: Boolean             -- every declared setting — scalar or complex
                                          -- (array/dict) — reads back as the desired value
}

variant GitCloneAction : Action {
    url: String
    ref: String?
    repo_exists: Boolean
    head_matches_ref: Boolean
}

variant ClaudeResourceAction : Action {
    -- A Claude Code marketplace, plugin or MCP server registration.
    resource_kind: marketplace | plugin | mcp_server
    present: Boolean                      -- registered/installed on the machine
    update_available: Boolean             -- the installed version is behind the
                                          -- marketplace catalogue, after the catalogue
                                          -- has been refreshed from its source
}

-- =============================================================================
-- Config
-- =============================================================================

config {
    plan_ttl: Duration = 5.minutes        -- a captured plan is only replayable
                                          -- within this window of being captured;
                                          -- beyond it the machine may have drifted
                                          -- while the operator was away
}

-- =============================================================================
-- Invocation and plan assembly
-- =============================================================================

rule OperatorInvokesSyn {
    when: SynInvoked(_, scope, mode, fresh)
    ensures: Run.created(mode: mode, scope: scope, fresh: fresh, status: planning)
}

rule ReplayStoredPlan {
    -- A default apply (not --fresh) with a valid persisted plan replays it:
    -- assembly and the live check phase are skipped entirely. The plan's
    -- captured actions are loaded onto this run with the outcomes they were
    -- checked with, and execution proceeds straight to applying. Captured
    -- validation errors still gate the apply exactly as ApplyGate would, with
    -- no recomputation.
    when: run: Run.status becomes planning
    requires: run.status = planning
    requires: run.mode = apply
    requires: not run.fresh
    requires: not manifest.has_escaping_source
    requires: not manifest.references_undefined_secret
    requires: cache.stored_plan != null
    requires: cache.stored_plan.valid_for(manifest.identity, run.scope)

    let plan = cache.stored_plan

    ensures:
        if plan.source_run.validation_errors.count > 0:
            run.status = aborted
        else:
            run.replayed_plan = plan
            for action in plan.source_run.actions:
                action.run = run
            run.status = applying
    @guidance
        -- Loading a plan re-associates its checked actions with this run; the
        -- outcomes recorded at plan time (satisfied / drift / conflict /
        -- cancelled …) are replayed as-is, so no package manager or filesystem
        -- is queried again. install_succeeds is still the live outcome of
        -- attempting each action at apply time.
}

rule ApplyWithoutValidPlanAborts {
    -- A default apply with no valid persisted plan refuses rather than falling
    -- back to a live check. This covers: never planned, manifest changed since
    -- planning (identity mismatch), scope mismatch, or an already-spent plan.
    when: run: Run.status becomes planning
    requires: run.status = planning
    requires: run.mode = apply
    requires: not run.fresh
    requires: not manifest.has_escaping_source
    requires: not manifest.references_undefined_secret
    requires: cache.stored_plan = null
             or not cache.stored_plan.valid_for(manifest.identity, run.scope)
    ensures: run.status = aborted
    @guidance
        -- The operator is directed to run `syn` first to plan, or to re-run
        -- with `--fresh` to check the machine live and apply in one pass.
}

rule ReferencingUndefinedSecretAborts {
    -- A module manifest may reference a secret by key. If no secret with that
    -- key is defined, the run aborts before any plan is assembled.
    when: run: Run.status becomes planning
    requires: run.status = planning
    requires: manifest.references_undefined_secret
    ensures: run.status = aborted
}

rule PathEscapeAbortsRun {
    when: run: Run.status becomes planning
    requires: run.status = planning
    requires: manifest.has_escaping_source
    ensures: run.status = aborted
    @guidance
        -- A relative source path in a module manifest is resolved against the
        -- module's own directory; a path that canonicalises outside that
        -- directory is rejected. Absolute and ~-prefixed paths are exempt.
}

rule AssemblePlan {
    when: run: Run.status becomes planning
    requires: run.mode = plan or run.fresh   -- the live path only; a default apply replays
    requires: not manifest.has_escaping_source
    requires: not manifest.references_undefined_secret

    -- One Action is created per declared item across all module manifests,
    -- identified by (action type, key). Relative source paths are resolved
    -- against the declaring module's directory. A symlink-folder declaration
    -- stands for one symlink per file found under the folder, preserving the
    -- file's relative path under the declared link prefix.
    ensures:
        for folder in manifest.folder_declarations:
            for file in folder.files:
                SymlinkAction.created(
                    run: run,
                    target: folder.link_prefix + file.relative_path,
                    source: file.absolute_path
                )
    ensures: PlanAssembled(run)
    @guidance
        -- Declarations of the same action type from different modules are
        -- merged into a single collection before graph construction.
}

rule FlagDuplicateDeclarations {
    -- The same (action type, key) declared by more than one module is a
    -- validation error naming all declaring sources. It does not stop the
    -- plan from being displayed; it blocks apply.
    when: PlanAssembled(run)
    for action in run.actions where declaring_modules.count > 1:
        ensures: ValidationError.created(
            run: run,
            subject: action.key,
            description: "declared in multiple modules"
        )
}

rule FlagInvalidSecrets {
    -- A defined secret with an empty value (and not explicitly disabled) is a
    -- validation error — even if nothing currently references it.
    when: PlanAssembled(run)
    for secret in Secrets where invalid:
        ensures: ValidationError.created(
            run: run,
            subject: secret.key,
            description: "empty secret value (disable it to opt out)"
        )
}

rule ScheduleStaleUnlinks {
    -- A symlink recorded in the cache but absent from the current plan was
    -- previously created by syn and is now stale: an unlink action is added.
    when: PlanAssembled(run)
    for record in cache.recorded_symlinks:
        ensures:
            if not run.actions.any(a => a.kind = SymlinkAction and a.target = record.target):
                UnlinkAction.created(
                    run: run,
                    target: record.target,
                    expected_source: record.source
                )
}

rule ScheduleOrphanUninstalls {
    -- The manifest is the single source of truth for every package manager
    -- syn can drive: anything explicitly installed but not declared is drift
    -- to be removed. Every available manager with orphan detection is
    -- therefore queried on every run — whether or not the manifest declares
    -- anything for it (removing a manager's last declaration means "nothing
    -- should be installed via this manager", not "stop managing it").
    -- Undeclared items become uninstall actions, ordered after every action
    -- of the base type.
    when: PlanAssembled(run)
    for manager in PackageManagers where available and supports_orphan_detection:
        ensures:
            for item in manager.explicitly_installed:
                if not run.actions.any(a => a.kind = PackageAction and a.key = item):
                    UninstallAction.created(run: run, manager: manager, key: item)
    @guidance
        -- Tap-qualified names (e.g. babashka/brew/bbin) match their short
        -- form (bbin) when comparing declared names against installed ones.
}

rule ScheduleOrphanSourceRemovals {
    -- The single-source-of-truth stance extends to package sources: a
    -- third-party source is justified only by declared packages that come
    -- from it. An installed source no declaration uses is drift to be
    -- removed; removing it also drops any trust grants made under it.
    when: PlanAssembled(run)
    for manager in PackageManagers where available and supports_orphan_detection:
        ensures:
            for source in manager.third_party_sources:
                if not run.actions.any(a => a.kind = PackageAction and a.source = source):
                    SourceRemovalAction.created(run: run, manager: manager, source: source)
    @guidance
        -- Homebrew taps are the only third-party sources today. Orphanhood
        -- is judged against declared packages, not installed ones, so a
        -- source whose last installed package is an orphan being removed
        -- this run is itself removed in the same run.
}

rule GraphErrorsAbortRun {
    when: PlanAssembled(run)
    requires: run.graph_errors
    ensures: run.status = aborted
}

rule EmptyScopeAborts {
    when: PlanAssembled(run)
    requires: run.scope != null
    requires: not run.actions.any(a => a.in_scope)
    ensures: run.status = aborted
}

rule ScopeFilterRemovesUnrelatedActions {
    when: PlanAssembled(run)
    requires: run.scope != null
    requires: not run.graph_errors
    ensures:
        for action in run.actions:
            if not action.in_scope:
                not exists action
}

rule BeginChecks {
    when: PlanAssembled(run)
    requires: not run.graph_errors
    requires: run.scope = null or run.actions.any(a => a.in_scope)
    ensures: run.status = checking
    @guidance
        -- Graph validation and the scope filter run after stale unlinks and
        -- orphan uninstalls have been merged into the plan, so injected
        -- actions participate in ordering and validation.
}

-- =============================================================================
-- Check phase
-- =============================================================================

-- Checks run in dependency order and are read-only: no check mutates the
-- machine. Each action family determines its outcome from live system state.

rule CheckSymlinks {
    when: run: Run.status becomes checking
    for action in run.actions where kind = SymlinkAction:
        ensures:
            if action.target_exists and action.target_is_symlink and action.target_points_at_source:
                action.check_outcome = satisfied
            else if action.target_exists and action.target_is_symlink:
                action.check_outcome = drift
            else if action.target_exists:
                action.check_outcome = conflict
            else:
                action.check_outcome = drift
    @guidance
        -- Symlink drift kinds: an existing symlink pointing elsewhere is
        -- drift/wrong; a missing link is drift/missing. A regular file at the
        -- target is a conflict requiring manual intervention.
}

rule CheckUnlinks {
    when: run: Run.status becomes checking
    for action in run.actions where kind = UnlinkAction:
        ensures:
            if not action.target_exists:
                action.check_outcome = satisfied
            else if not action.target_is_symlink:
                action.check_outcome = conflict
            else if not action.target_points_at_expected:
                action.check_outcome = conflict
            else:
                action.check_outcome = drift
    @guidance
        -- Stale links are removed only when they are provably syn's: a
        -- symlink pointing exactly where the cache recorded. Anything else
        -- at the target is a conflict, never deleted. Drift kind is orphan.
}

rule CheckPackages {
    when: run: Run.status becomes checking
    for action in run.actions where kind = PackageAction:
        ensures:
            if action.trusted = false and action.trust_declared:
                action.check_outcome = drift
            else if action.trusted = true and not action.trust_declared:
                action.check_outcome = drift
            else if action.trusted = false and not action.trust_declared and not action.installed:
                action.check_outcome = conflict
            else if action.trusted = false and not action.trust_declared:
                action.check_outcome = satisfied
            else if action.installed and action.upgrade_available:
                action.check_outcome = drift
            else if action.installed:
                action.check_outcome = satisfied
            else:
                action.check_outcome = drift
        ensures:
            if action.trusted = false and not action.trust_declared:
                if action.installed:
                    action.check_message = "untrusted tap — declare :trust to re-enable updates"
                else:
                    action.check_message = "untrusted tap — declare :trust to allow install"
    @guidance
        -- Drift kind is outdated (with an "installed → desired" message) when
        -- an upgrade is available, missing otherwise. A version-pinned tool
        -- is outdated when the pinned version is not installed; a "latest"
        -- tool is outdated when the manager reports a newer version. A mise
        -- tool declared without a version is a check error.
        -- Trust branches precede installed/outdated because the manager
        -- ignores items from untrusted sources — its installed and outdated
        -- answers are unreliable for them. Homebrew is the only manager
        -- that enforces source trust today. Trust drift kind is wrong:
        -- declared-but-ungranted trust is granted on apply,
        -- granted-but-undeclared trust is revoked. An unconsented item that
        -- is not installed is a conflict — the install is known to fail, so
        -- it is never attempted; an unconsented item that is installed
        -- remains satisfied but warned. Either way the remediation is the
        -- same: declare :trust on the package (or remove it).
}

rule CheckUninstalls {
    when: run: Run.status becomes checking
    for action in run.actions where kind = UninstallAction:
        ensures:
            action.check_outcome = drift
    @guidance
        -- Orphans always need action by construction; drift kind is orphan.
}

rule CheckSourceRemovals {
    when: run: Run.status becomes checking
    for action in run.actions where kind = SourceRemovalAction:
        ensures:
            action.check_outcome = drift
    @guidance
        -- Orphaned sources always need action by construction; drift kind
        -- is orphan.
}

rule CheckScripts {
    when: run: Run.status becomes checking
    for action in run.actions where kind = ScriptAction:
        ensures:
            if not action.has_check:
                action.check_outcome = unknown
            else if action.check_passes:
                action.check_outcome = satisfied
            else:
                action.check_outcome = drift
    @guidance
        -- The check command is told whether the script content has changed
        -- since its last successful run (via an environment flag), so a check
        -- can force a re-run on content change. A script with no check
        -- command runs on every apply.
}

rule CheckAssertions {
    when: run: Run.status becomes checking
    for action in run.actions where kind = AssertAction:
        ensures:
            if action.condition_holds:
                action.check_outcome = satisfied
            else:
                action.check_outcome = error
    @guidance
        -- A failed assertion reports its declared message and remediation
        -- instructions. As an error outcome it blocks everything that
        -- depends on it — assertions gate their dependents.
}

rule CheckServices {
    when: run: Run.status becomes checking
    for action in run.actions where kind = ServiceAction:
        ensures:
            if action.running:
                action.check_outcome = satisfied
            else if action.needs_sudo and action.root_owned:
                action.check_outcome = satisfied
            else:
                action.check_outcome = drift
    @guidance
        -- Root-owned services are invisible to a non-sudo status query, so a
        -- declared sudo service owned by root is assumed running.
}

rule CheckDefaults {
    when: run: Run.status becomes checking
    for action in run.actions where kind = DefaultsAction:
        ensures:
            if action.all_values_match:
                action.check_outcome = satisfied
            else:
                action.check_outcome = drift
    @guidance
        -- Drift kind is wrong. Every declared value is compared against the
        -- live system, including array and dict values.
}

rule CheckGitClones {
    when: run: Run.status becomes checking
    for action in run.actions where kind = GitCloneAction:
        ensures:
            if not action.repo_exists:
                action.check_outcome = drift
            else if action.ref != null and not action.head_matches_ref:
                action.check_outcome = drift
            else:
                action.check_outcome = satisfied
        ensures:
            if action.repo_exists and action.ref = null:
                action.check_message = "no ref declared — existing repository is never updated"
    @guidance
        -- Missing repo is drift/missing; wrong ref is drift/outdated. A repo
        -- with no declared ref is satisfied by mere existence, but the report
        -- warns the operator that it will never be updated.
}

rule CheckClaudeResources {
    when: run: Run.status becomes checking
    for action in run.actions where kind = ClaudeResourceAction:
        ensures:
            if not action.present:
                action.check_outcome = drift
            else if action.update_available:
                action.check_outcome = drift
            else:
                action.check_outcome = satisfied
    @guidance
        -- Missing registration is drift/missing; a stale version is
        -- drift/outdated. A present, current resource is satisfied and is
        -- not re-registered.
        -- Version discovery for plugins refreshes the marketplace catalogues
        -- from their sources once per run (a network read) and then compares
        -- the installed version against the catalogue; a plugin whose
        -- catalogue records no version cannot drift by version. Outdated
        -- plugins are remedied by an update, not a reinstall.
        -- MCP servers are managed at user (machine-global) scope only —
        -- presence is read from the user-scope registry. Declaring a
        -- project- or local-scope server is a check error: those
        -- registrations belong to the individual projects they serve, not
        -- the dotfiles manifest.
}

rule BlockingOutcomeCancelsDependents {
    -- Errors, conflicts and cancellations propagate: everything that depends
    -- (directly or, via this rule's cascade, transitively) on a blocked
    -- action is cancelled and will not be attempted.
    when: action: Action.blocking
    ensures:
        for dep in action.run.actions:
            if action in dep.depends_on:
                dep.check_outcome = cancelled
}

rule ChecksLeadToDisplay {
    when: run: Run.all_checked
    requires: run.status = checking
    requires: run.mode = plan
    ensures: run.status = displaying
}

rule ApplyGate {
    -- Apply is blocked outright when the manifest has duplicate declarations
    -- or when any defined secret is empty without being disabled — even a
    -- secret nothing currently references.
    when: run: Run.all_checked
    requires: run.status = checking
    requires: run.mode = apply
    ensures:
        if run.validation_errors.count > 0:
            run.status = aborted
        else:
            run.status = applying
}

-- =============================================================================
-- Display (plan mode)
-- =============================================================================

rule DisplayPlan {
    -- Plan mode reports every action that is not already satisfied, grouped
    -- by action type, with its drift kind or blocking reason and a summary
    -- count by state — and every validation error that would block an apply.
    -- It changes nothing on the machine.
    when: run: Run.status becomes displaying
    requires: run.status = displaying
    ensures: run.status = complete
}

rule PersistCheckedPlan {
    -- A plan-mode run captures its checked plan when checking completes, so a
    -- later default apply can replay it. The capture is tagged with the manifest
    -- identity and the scope in force and starts unspent. Only one plan is kept:
    -- any earlier capture is discarded. Writing the plan cache is a write to
    -- syn's own state, not a change to the machine — no action result is touched.
    when: run: Run.status transitions_to displaying
    requires: run.mode = plan
    ensures:
        if cache.stored_plan != null:
            not exists cache.stored_plan
    ensures: StoredPlan.created(
        cache: cache,
        source_run: run,
        manifest_identity: manifest.identity,
        scope: run.scope,
        spent: false,
        captured_at: now
    )
}

-- =============================================================================
-- Apply
-- =============================================================================

rule ExecuteActions {
    -- Actions are attempted in dependency order. Satisfied actions are
    -- skipped; blocked actions are skipped and reported; actionable actions
    -- (drift or unknown) are attempted.
    when: run: Run.status becomes applying
    for action in run.actions:
        ensures:
            if action.check_outcome = satisfied:
                action.result = skipped
            else if action.blocking:
                action.result = skipped
            else if action.install_succeeds:
                action.result = applied
            else:
                action.result = failed
    @guidance
        -- Consecutive actionable actions of the same type are batched into a
        -- single installer invocation; a batch is flushed when the type
        -- changes or when an action depends on something still in the batch.
        -- This is an efficiency choice, not observable ordering behaviour.
        -- Applying a package whose live trust diverges from its declaration
        -- reconciles the grant (granting before installing, so the manager
        -- will load the item). Trust is granted per item, never for a whole
        -- source — whole-source trust would extend to items the manifest
        -- never declared. Uninstalling a third-party orphan also revokes
        -- any grant made for it.
}

rule ApplyCompletes {
    when: run: Run.all_resolved
    requires: run.status = applying
    ensures: run.status = complete
}

rule SpendStoredPlanOnApply {
    -- Any apply that reaches completion has mutated the machine, so the captured
    -- plan no longer describes the current world: it is spent and can never be
    -- replayed. This consumes the plan a replay-apply replayed (here
    -- cache.stored_plan is that same plan, so a second bare apply refuses), and
    -- invalidates a stale plan a --fresh apply ignored and checked past. An
    -- apply that aborts (e.g. on validation errors) touches nothing and leaves
    -- the captured plan intact.
    when: run: Run.status transitions_to complete
    requires: run.mode = apply
    requires: cache.stored_plan != null
    ensures: cache.stored_plan.spent = true
}

rule FailedActionBlocksDependents {
    when: action: Action.result becomes failed
    ensures: action.check_outcome = error
    -- BlockingOutcomeCancelsDependents then cancels everything downstream.
}

rule RecordScriptRun {
    -- A successful script run records the identity of the content that ran,
    -- so future checks can detect content changes.
    when: action: Action.result becomes applied
    requires: action.kind = ScriptAction
    ensures: ScriptRecord.created(
        cache: cache,
        script_name: action.key,
        content_hash: action.content
    )
}

rule PersistSymlinkOwnership {
    -- After an apply, the ownership record is updated from what this run
    -- actually observed. A planned link is recorded when its action was
    -- applied or already satisfied; failed or conflicted links are not
    -- recorded — syn never claims ownership of a link it did not make.
    -- A stale record is dropped once its unlink resolved: the link was
    -- removed, already gone, or turned out not to be syn's (conflict).
    -- Records whose target was not attempted this run — excluded by a scope
    -- filter, or cancelled — are retained untouched, so ownership survives
    -- partial runs and pending unlinks are rescheduled.
    when: run: Run.status transitions_to complete
    requires: run.mode = apply
    ensures:
        for old in cache.recorded_symlinks:
            if run.actions.any(a => a.kind = SymlinkAction and a.target = old.target)
               or run.actions.any(a => a.kind = UnlinkAction and a.target = old.target and
                                       (a.result = applied
                                        or a.check_outcome = satisfied
                                        or a.check_outcome = conflict)):
                not exists old
    ensures:
        for action in run.actions:
            if action.kind = SymlinkAction and
               (action.result = applied or action.check_outcome = satisfied):
                RecordedSymlink.created(
                    cache: cache,
                    target: action.target,
                    source: action.source
                )
}

-- =============================================================================
-- Surfaces
-- =============================================================================

surface CommandLine {
    facing operator: Operator

    provides:
        SynInvoked(operator, scope, mode, fresh)

    @guarantee PlanModeIsHarmless
        -- Invoking without apply mode only inspects the machine; nothing on
        -- the machine is installed, linked or removed. Plan mode does write
        -- syn's own persisted plan cache — capturing the checked plan for a
        -- later apply to replay — but that is a write to syn's own state, not
        -- a change to the machine's configuration. Version discovery may
        -- likewise refresh package managers' own metadata caches (marketplace
        -- catalogues, registry indexes) — a read of the outside world, not a
        -- change to the machine's configuration.
}

surface RunReport {
    facing operator: Operator

    context run: Run

    exposes:
        for action in run.unsatisfied_actions:
            action.key
            action.check_outcome
            action.check_message
        for action in run.warned_actions:
            action.key
            action.check_message
        for error in run.validation_errors:
            error.subject
            error.description

    @guarantee ActionableSummary
        -- The report groups unsatisfied actions by type, distinguishes what
        -- will be installed, upgraded or removed from what is blocked, and
        -- includes remediation instructions for failed assertions.

    @guarantee ValidationVisibleBeforeApply
        -- Anything that would block an apply (duplicate declarations, empty
        -- secrets) is already visible in the plan report.
}

-- =============================================================================
-- Invariants
-- =============================================================================

invariant BlockedActionsAreNeverApplied {
    for action in Actions:
        action.blocking implies action.result != applied
}

-- Trust is fully declarative: the manifest's :trust declaration is the
-- single source of truth for a grant. Applying a package converges its
-- live grant on the declaration — granting when declared, revoking when
-- not — so no grant outlives the declaration that justified it.
invariant AppliedTrustMatchesDeclaration {
    for action in Actions:
        action.kind = PackageAction and action.result = applied and action.trusted != null
            implies action.trusted = action.trust_declared
}

invariant SatisfiedActionsAreNotReapplied {
    for action in Actions:
        action.check_outcome = satisfied implies action.result != applied
}

-- Read-only means syn itself never mutates during plan mode. Script and
-- assert checks execute manifest-author-supplied commands; keeping those
-- commands side-effect-free is the manifest author's responsibility — the
-- framework does not (and cannot) enforce it.
invariant PlanModeIsReadOnly {
    for run in Runs:
        run.mode = plan implies run.actions.all(a => a.result = pending)
}

invariant OnlyOwnedSymlinksAreRemoved {
    for action in Actions:
        action.kind = UnlinkAction and action.result = applied
            implies action.target_points_at_expected
}

-- A persisted plan is consumed by at most one replay: once a replay-apply
-- completes it is spent, and a spent plan is never valid to replay again. No
-- two runs ever replay the same stored plan, so a plan's recorded decisions
-- are never applied to the machine twice.
invariant StoredPlanReplayedAtMostOnce {
    for a in Runs:
        for b in Runs:
            a != b and a.replayed_plan != null and b.replayed_plan != null
                implies a.replayed_plan != b.replayed_plan
}

