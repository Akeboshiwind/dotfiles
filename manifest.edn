{:plan [;; >> Bootstrap (provides :pkg/brew, :pkg/mise, :pkg/mas, :pkg/bbin, :brew/service)
        {:pkg/script
         {:homebrew
          {:path "scripts/install-homebrew.sh"
           :check "command -v brew"
           :dep/provides #{:pkg/brew :brew/service}}}
         :pkg/brew
         {:mise {:dep/provides #{:pkg/mise}}
          :mas {:dep/provides #{:mas/installed}}
          "babashka/brew/bbin" {:trust true :dep/provides #{:pkg/bbin}}}
         :assert
         {:app-store-signed-in
          {:src "defaults read MobileMeAccounts Accounts 2>/dev/null | grep -q 'AccountID'"
           :message "Not signed in to Apple ID (required for App Store)"
           :instructions ["Open System Settings > Apple ID and sign in"]
           :dep/requires #{:mas/installed}
           :dep/provides #{:pkg/mas}}}}

        ;; >> OSX
        :macos

        ;; >> Terminal setup
        :ghostty
        :tmux
        :fish
        :bash

        ;; >> Editor
        :nvim
        :vim
        :intellij

        ;; >> Tools
        {:pkg/bbin {:hello {:local "./tools/hello"}}}
        :tailscale
        :git
        :ssh
        :gpg
        :fzf
        :zoxide
        :bin

        ;; >> Languages
        :clojure
        :js
        :terraform
        :python

        ;; >> Deployment
        :aws
        :fly
        :kubernetes
        :cloudflare

        ;; >> AI
        :llm

        ;; >> Work
        {:pkg/brew {:slack {}}
         :pkg/mas {"Windows App" 1295203466}}
        {:pkg/brew {:tunnelblick {}}}

        {:pkg/brew {"postgresql@18" {}}}
        ; To run the XTDB docs site
        {:pkg/brew {:yarn {}
                    :d2 {}}}

        ;; >> Launcher
        :tinystart

        ;; >> Reading
        :calibre

        ;; >> Fun
        {:pkg/brew {:godot {}
                    :telegram {}
                    :musescore {}}}]}
